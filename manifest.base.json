{
	"name": "PASRS Helper",
	"description": "Auto-saves your Pokémon Showdown replays and fills a PASRS Google Sheet with your stats — picks, leads, tera, Elo and matchups.",
	"version": "1.2.4",
	"manifest_version": 3,
	"icons": {
		"16": "icons/icon-16.png",
		"32": "icons/icon-32.png",
		"48": "icons/icon-48.png",
		"96": "icons/icon-96.png",
		"128": "icons/icon-128.png"
	},
	"permissions": ["storage", "identity"],
	"host_permissions": [
		"*://*.pokemonshowdown.com/*",
		"*://*.psim.us/*",
		"https://sheets.googleapis.com/*",
		"https://www.googleapis.com/*",
		"https://pokepast.es/*"
	],
	"oauth2": {
		"client_id": "399755851205-l7i2g4jrqbgv9a8lsrqe8drbo1lqdg19.apps.googleusercontent.com",
		"scopes": ["https://www.googleapis.com/auth/drive.file"]
	},
	"background": {
		"service_worker": "dist/background.js"
	},
	"content_scripts": [
		{
			"matches": ["*://play.pokemonshowdown.com/*", "*://*.psim.us/*"],
			"js": ["dist/extension.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["dist/*.js", "dist/*.css"],
			"matches": ["*://play.pokemonshowdown.com/*", "*://*.psim.us/*"]
		}
	]
}
