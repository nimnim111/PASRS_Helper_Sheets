{
	"name": "PASRS Helper",
	"description": "Automatically uploads the replay of your last battle in PSD.",
	"version": "1.1.0",
	"manifest_version": 3,
	"icons": {
		"128": "128.png"
	},
	"permissions": ["storage"],
	"host_permissions": ["*://*.pokemonshowdown.com/*", "*://*.psim.us/*"],
	"content_scripts": [
		{
			"matches": ["*://play.pokemonshowdown.com/*", "*://*.psim.us/*"],
			"js": ["dist/extension.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"dist/*.js",
				"dist/*.css"
			],
			"matches": ["*://play.pokemonshowdown.com/*", "*://*.psim.us/*"]
		}
	]
}
