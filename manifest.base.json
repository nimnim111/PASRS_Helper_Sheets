{
	"name": "PASRS Helper",
	"description": "Automatically uploads the replay of your last battle in PSD.",
	"version": "1.1.0",
	"manifest_version": 3,
	"icons": {
		"128": "128.png"
	},
	"permissions": ["storage", "identity"],
	"host_permissions": [
		"*://*.pokemonshowdown.com/*",
		"*://*.psim.us/*",
		"https://sheets.googleapis.com/*"
	],
	"oauth2": {
		"client_id": "REPLACE_WITH_YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
		"scopes": ["https://www.googleapis.com/auth/spreadsheets"]
	},
	"background": {
		"service_worker": "dist/background.js"
	},
	"content_scripts": [
		{
			"matches": ["*://play.pokemonshowdown.com/*", "*://*.psim.us/*"],
			"js": ["dist/extension.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"dist/*.js",
				"dist/*.css"
			],
			"matches": ["*://play.pokemonshowdown.com/*", "*://*.psim.us/*"]
		}
	]
}
