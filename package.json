{
	"name": "test",
	"private": true,
	"version": "1.2.4",
	"type": "module",
	"scripts": {
		"build": "node build.mjs",
		"build:chrome": "node build.mjs chrome",
		"build:firefox": "node build.mjs firefox",
		"dev": "bun run dev_server.ts chrome",
		"dev:chrome": "bun run dev_server.ts chrome",
		"dev:firefox": "bun run dev_server.ts firefox",
		"check": "biome check --write",
		"react:dev": "rsbuild dev --open",
		"format": "biome format --write",
		"preview": "rsbuild preview",
		"release": "bun release.mjs",
		"source:zip": "git archive --format=zip -o source.zip HEAD",
		"sign:firefox": "npm run build:firefox && web-ext sign --source-dir output --channel=unlisted",
		"sign:firefox-listed": "npm run build:firefox && npm run source:zip && web-ext sign --source-dir output --channel=listed --upload-source-code source.zip"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@rsbuild/core": "^1.3.15",
		"@rsbuild/plugin-react": "^1.3.0",
		"@types/chrome": "^0.1.40",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.3",
		"chokidar": "^4.0.3",
		"chrome-webstore-upload-cli": "^3.5.0",
		"typescript": "^5.8.3",
		"web-ext": "^8.3.0"
	},
	"dependencies": {
		"@swc/helpers": "^0.5.17",
		"@types/jquery": "^3.5.31",
		"@types/node": "^22.7.5",
		"jquery": "^3.7.1",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"styled-components": "^6.4.0"
	}
}
